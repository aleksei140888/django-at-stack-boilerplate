[flake8]
max-line-length = 100
extend-ignore =
    # E501 line too long — handled by black
    E501,
    # W503 line break before binary operator — black style
    W503,
    # E203 whitespace before ':' — black style
    E203,
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    migrations,
    staticfiles,
    node_modules,
    dist,
    build,
per-file-ignores =
    # Allow star imports in settings
    config/settings/*.py: F401, F403, F405
    # Allow unused imports in __init__.py
    */__init__.py: F401
